# Streamlit Cloud Secrets Template
# Copy these to Settings -> Secrets in your Streamlit Cloud dashboard.
# Do NOT commit the real secrets.toml file (it is gitignored).

GROQ_API_KEY = "gsk_your_groq_api_key_here"
USE_CHROMA_CLOUD = "false"

# Only needed if USE_CHROMA_CLOUD = "true":
# CHROMA_API_KEY = "your_chroma_cloud_key"
# CHROMA_TENANT = "your_tenant_id"
# CHROMA_DATABASE = "customer-churn"
